# --- Aplicação ---
APP_NAME=Aureye API
ENVIRONMENT=development
API_PREFIX=/api
CORS_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost

# --- MongoDB ---
MONGO_URI=mongodb://mongodb:27017
MONGO_DB_NAME=aureye

# --- Sessão / JWT ---
# TROQUE em produção por um segredo forte (ex: `openssl rand -hex 32`)
JWT_SECRET=dev-insecure-secret-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=10080
COOKIE_NAME=aureye_session
# Em produção (HTTPS) mantenha true
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# --- Autenticação Google ---
# Client ID do Google Identity Services (obrigatório pra login real do Google)
GOOGLE_CLIENT_ID=
# Login de desenvolvimento sem OAuth (NÃO habilite em produção)
DEV_AUTH_ENABLED=true
# E-mail semeado como admin na primeira subida (allowlist inicial)
SEED_ADMIN_EMAIL=admin@example.com

# --- Features (IA mock) ---
# Liga/desliga o endpoint (e o botão no frontend) de extração mock de dados
# da receita a partir da imagem.
EXTRACAO_IA_ENABLED=true

# --- Storage (MinIO / S3) ---
# endpoint interno (rede do compose) usado pelo backend p/ operações de bucket
S3_ENDPOINT_INTERNAL=http://minio:9000
# endpoint público usado p/ assinar as presigned URLs acessadas pelo navegador
S3_ENDPOINT_PUBLIC=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=receitas
S3_REGION=us-east-1
S3_PRESIGN_EXPIRES=900
