# Copie para `.env` na raiz para customizar o docker-compose.
# Todos têm defaults no compose — o .env é opcional.

# --- App ---
MONGO_DB_NAME=aureye
# Troque em produção (ex: `openssl rand -hex 32`)
JWT_SECRET=dev-insecure-secret-change-me
# true quando servir por HTTPS
COOKIE_SECURE=false
CORS_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost

# --- Autenticação ---
# Client ID do Google Identity Services. Vazio -> usa login de desenvolvimento.
GOOGLE_CLIENT_ID=
DEV_AUTH_ENABLED=true
# E-mail semeado como admin na allowlist na primeira subida.
SEED_ADMIN_EMAIL=admin@example.com

# --- Features (IA mock) ---
# Liga/desliga o botão "Preencher com IA" (extração mock de dados da receita
# a partir da imagem) e o endpoint correspondente. Controla backend e
# frontend com uma única variável.
EXTRACAO_IA_ENABLED=true

# --- Features (Agente) ---
# Liga/desliga a aba "Agente" (chat com agente de linguagem natural real via
# LangChain/Groq; as tools que ele aciona são reais no banco). Controla
# backend e frontend com uma única variável.
AGENTE_ENABLED=true

# --- Agente (LLM real via Groq) ---
# Chave da API do Groq (console.groq.com/keys). Sem ela, o endpoint do
# agente fica indisponível (404) mesmo com AGENTE_ENABLED=true.
GROQ_API_KEY=
# Modelo primário e fallback (separado por vírgula, sem espaço), iniciados
# via langchain.chat_models.init_chat_model. Raramente precisa mudar.
# GROQ_MODEL_PRIMARY=openai/gpt-oss-120b
# GROQ_MODEL_FALLBACKS=openai/gpt-oss-20b

# --- Storage (MinIO) ---
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=receitas
# Endpoint público que o NAVEGADOR usa nas presigned URLs.
S3_ENDPOINT_PUBLIC=http://localhost:9000
# Opcional: só necessário quando um proxy entre o browser e o MinIO reescreve
# o header Host (ex: GitHub Codespaces). Ver comentário em app/config.py.
# S3_SIGN_ENDPOINT=http://localhost:9000
# Origens permitidas no CORS do MinIO (PUT direto do browser). * em dev.
MINIO_CORS_ALLOW_ORIGIN=*
