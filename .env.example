# Copie para `.env` na raiz para customizar o docker-compose.
# Todos têm defaults no compose — o .env é opcional.

# --- App ---
MONGO_DB_NAME=aureye
# Troque em produção (ex: `openssl rand -hex 32`)
JWT_SECRET=dev-insecure-secret-change-me
# true quando servir por HTTPS
COOKIE_SECURE=false
CORS_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost

# --- Autenticação ---
# Client ID do Google Identity Services. Vazio -> usa login de desenvolvimento.
GOOGLE_CLIENT_ID=
DEV_AUTH_ENABLED=true
# E-mail semeado como admin na allowlist na primeira subida.
SEED_ADMIN_EMAIL=admin@example.com

# --- Storage (MinIO) ---
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=receitas
# Endpoint público que o NAVEGADOR usa nas presigned URLs.
S3_ENDPOINT_PUBLIC=http://localhost:9000
# Origens permitidas no CORS do MinIO (PUT direto do browser). * em dev.
MINIO_CORS_ALLOW_ORIGIN=*
