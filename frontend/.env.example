# Client ID do Google Identity Services. Sem ele, o login usa o modo dev.
VITE_GOOGLE_CLIENT_ID=

# Mostra o formulário de login de desenvolvimento (true|false).
VITE_DEV_AUTH=true

# Mostra o botão "Preencher com IA" no formulário de receita (true|false).
# O backend também precisa ter EXTRACAO_IA_ENABLED=true (senão o endpoint
# responde 404 mesmo com o botão visível).
VITE_EXTRACAO_IA_ENABLED=true

# Alvo do proxy /api quando rodando `npm run dev` fora do Docker.
VITE_API_PROXY_TARGET=http://localhost:8000
